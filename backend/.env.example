# PostgreSQL connection string from Neon (or any Postgres provider)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Random secret for signing JWTs — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# URL of the deployed frontend (used for CORS). Defaults to http://localhost:5173 if not set.
FRONTEND_URL=https://your-frontend-domain.com
